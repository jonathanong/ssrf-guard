{
  "name": "ssrf-guard",
  "version": "0.4.1",
  "description": "SSRF protection: validate URLs, pin resolved IPs to the socket, eliminating the DNS-rebind window",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jonathanong/ssrf-guard.git"
  },
  "files": [
    "src",
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/core/index.d.mts",
      "import": "./dist/core/index.mjs"
    },
    "./node": {
      "types": "./dist/node/index.d.mts",
      "import": "./dist/node/index.mjs"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepack": "pnpm run build",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "undici": "^8.4.1"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@vitest/coverage-v8": "^4.1.8",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.69.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=24"
  }
}
